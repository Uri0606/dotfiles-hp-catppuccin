{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["custom/music"],
    "modules-right": ["pulseaudio", "bluetooth", "backlight", "clock", "battery", "power-profiles-daemon", "network", "custom/kdeconnect", "custom/lock", "custom/power"],
    "hyprland/workspaces": {
        "disable-scroll": true,
        "sort-by-name": true,
        "format": " {icon} ",
        "format-icons": {
            "default": "Όχ┤"
        }
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "custom/music": {
        "format": "ΎΑΒ  {}",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ title }}'",
        "on-click": "playerctl play-pause",
        "max-length": 50
    },
    "clock": {
        "timezone": "America/Mexico_City",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "ΎΒ│ {:%d/%m/%Y}",
        "format": "ΎΑΩ {:%H:%M}"
    },
    "bluetooth": {
        "format": "ΎΛΦ {status}",
        "format-connected": "ΎΛΦ {device_alias}",
        "format-connected-battery": "ΎΛΦ {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "on-click": "blueman-manager"
    },
    "backlight": {
        "device": "amdgpu_bl1",
        "format": "{icon} {percent}%",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 25
        },
        "format": "{icon} {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-plugged": "≤░ΓΕ {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": ["≤░ΓΔ", "≤░Β╗", "≤░Β╜", "≤░ΓΑ", "≤░Β╣"],
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Perfil: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "ΎΔπ",
            "performance": "≤▒Υη",
            "balanced": "ΎΚΟ",
            "power-saver": "≤░Νς"
        }
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "≤░ζθ Muted",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "swaylock",
        "format": "ΎΑμ"
    },
    "custom/power": {
        "tooltip": false,
        "on-click": "wlogout &",
        "format": "ΎΑΣ"
    },
    "network": {
        "format-wifi": "ΎΘτ ",
        "format-disconnected": "≤░Ψς Off",
        "on-click": "kitty -e nmtui",
        "tooltip-format": "{ifname} via {gwaddr} ΎηΨ"
    },
    "custom/kdeconnect": {
        "format": "ΎΕΜ ",
        "on-click": "kdeconnect-app",
        "on-click-right": "kdeconnect-sms",
        "tooltip": false
    }
}